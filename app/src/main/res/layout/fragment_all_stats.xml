<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 All Streaks"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:fontFamily="@font/inter_bold"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:id="@+id/tvTotalHabits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="8dp"
                    android:text="📋 Total habits: 0" />

                <TextView android:id="@+id/tvActiveStreaks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="8dp"
                    android:text="🔥 Active streaks: 0" />

                <TextView android:id="@+id/tvLongestEver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:layout_marginBottom="8dp"
                    android:text="🏆 Longest streak ever: 0 days" />

                <TextView android:id="@+id/tvAvgStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface_variant"
                    android:text="📊 Avg current streak: 0 days" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leaderboard"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp"
            android:textColor="@color/on_surface"
            android:text="" />

        <View android:layout_width="match_parent" android:layout_height="24dp" />

    </LinearLayout>

</ScrollView>
