<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Habit"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/on_surface"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="Icon">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmoji"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="🔥"
                android:textSize="22sp"
                android:gravity="center" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="Habit name (e.g. Work out)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHabitName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickTime"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Set Reminder Time"
        app:icon="@android:drawable/ic_menu_recent_history" />

    <TextView
        android:id="@+id/tvSelectedTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_gravity="center_horizontal"
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp"
        android:text="Reminder: 8:00 PM" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveHabit"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="Create Habit"
        android:textSize="16sp"
        app:backgroundTint="@color/primary"
        android:textColor="@color/on_primary" />

    <View
        android:layout_width="match_parent"
        android:layout_height="16dp" />

</LinearLayout>
