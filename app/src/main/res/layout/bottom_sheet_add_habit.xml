<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvAddHabitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Habit"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Suggestions"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface_variant"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="16dp">
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupHabitSuggestions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true">
                <!-- Programmatically populated -->
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:hint="Icon">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmoji"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text="🔥"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:selectAllOnFocus="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:hint="Habit name (e.g. Work out)">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHabitName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:imeOptions="actionNext"
                    android:selectAllOnFocus="true" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickTime"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Set Reminder Time"
            app:icon="@android:drawable/ic_menu_recent_history" />

        <TextView
            android:id="@+id/tvSelectedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:text="Reminder: 8:00 PM" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Priority"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface_variant" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/togglePriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:checkedButton="@+id/btnPriorityMed">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPriorityHigh"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="High" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPriorityMed"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Med" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPriorityLow"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Low" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Times per day"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface_variant" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:hint="Target (e.g. 3)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTargetCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="1"
                android:imeOptions="actionDone"
                android:selectAllOnFocus="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvActiveDaysHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Repeat on (Daily by default)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMon"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="M" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTue"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="T" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWed"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="W" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThu"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="T" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFri"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="F" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSat"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="S" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSun"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="S" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveHabit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="Create Habit"
            android:textSize="16sp"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
